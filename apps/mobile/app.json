{
  "expo": {
    "name": "Stackpilot Inspector",
    "slug": "stackpilot-inspector",
    "version": "0.1.0",
    "scheme": "stackpilot",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Stackpilot DesktopのペアリングQRコードを読み取るためにカメラを使用します。"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stackpilot.inspector"
    },
    "android": {
      "package": "com.stackpilot.inspector",
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro"
    }
  }
}
